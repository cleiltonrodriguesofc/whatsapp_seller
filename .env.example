# ==========================================
# ⚠️ TEST ENVIRONMENT CONFIGURATION
# Set these variables for temporary testing.
# ==========================================

# Database (Supabase)
# CRITICAL: use the TRANSACTION-MODE pooler url (port 6543), NOT port 5432 (session mode).
# session mode caps at 15 clients total — transaction mode handles far more concurrent connections.
# find this url in: supabase dashboard → project settings → database → connection pooling → transaction
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# Evolution API Configuration (TESTING)
EVOLUTION_API_URL=https://evolution-api-v2-2-3-74ow.onrender.com
EVOLUTION_API_KEY=your_key_here
EVOLUTION_DB_URL=postgresql://user:pass@host/db

# AI Configuration (TESTING)
OPENAI_API_KEY=your_openai_key_here
